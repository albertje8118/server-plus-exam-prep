{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/license-token.schema.json",
  "title": "DRM License Token Payload",
  "description": "Signed license token payload. The license service must ensure exp is greater than iat before signing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "iss",
    "aud",
    "sub",
    "deviceId",
    "licenseId",
    "packId",
    "packVersion",
    "sku",
    "rights",
    "entitlementType",
    "iat",
    "exp",
    "offlineLeaseExpiresAt",
    "wrappedKey",
    "keyWrapAlgorithm",
    "contentCipher",
    "challenge"
  ],
  "properties": {
    "iss": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "aud": {
      "type": "string",
      "const": "desktop-player"
    },
    "sub": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "deviceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "licenseId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 128
    },
    "packVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "sku": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 128
    },
    "rights": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["open", "practice", "timed-exam"]
      }
    },
    "entitlementType": {
      "type": "string",
      "enum": ["subscription", "credit", "purchase", "grant"]
    },
    "iat": {
      "type": "integer",
      "minimum": 0
    },
    "exp": {
      "type": "integer",
      "minimum": 0
    },
    "offlineLeaseExpiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "wrappedKey": {
      "type": "string",
      "contentEncoding": "base64",
      "minLength": 1
    },
    "keyWrapAlgorithm": {
      "type": "string",
      "enum": ["rsa-oaep-256", "ecdh-p256"]
    },
    "contentCipher": {
      "type": "string",
      "enum": ["aes-256-gcm"]
    },
    "challenge": {
      "type": "string",
      "minLength": 8,
      "maxLength": 512
    }
  }
}